<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback configuration for the Notification Service.

  Readable console output with correlation IDs for tracing.

  MDC fields included in log output:
    - correlationId  (set by CorrelationIdFilter for HTTP requests)
    - notificationId (set by NotificationConsumer for Kafka processing)
-->
<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) [%thread] %cyan(%logger{36}) - [cid=%X{correlationId}] [nid=%X{notificationId}] %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>

    <logger name="com.notificationservice" level="DEBUG" />
    <logger name="org.apache.kafka" level="WARN" />

    <statusListener class="ch.qos.logback.core.status.OnConsoleStatusListener" />
</configuration>
